                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "NCX71",
                      "name": "fk1",
                      "fill": "#e6edf3",
                      "content": "Ano ang Fork?",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "tjJMB",
                      "name": "fk2",
                      "fill": "#8b949e",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Ang fork ay isang personal na kopya ng ibang tao o organisasyon na repository. Kapag nag-fork ka, may sarili kang version ng repo na nasa iyong account.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "zzOO4",
                      "name": "fk3",
                      "fill": "#8b949e",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Hindi mo mababago ang original repo nang direkta, kailangan mong mag-open ng Pull Request mula sa iyong fork. Ito ang nagpoprotekta sa original project mula sa unauthorized changes.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "SbvQc",
                      "name": "fk4",
                      "fill": "#8b949e",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Halimbawa: Gusto mong mag-contribute sa isang popular na open-source library. I-fork mo ito, gumawa ng changes sa iyong fork, tapos mag-open ng PR sa original repo.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    }
                  ]
                },
